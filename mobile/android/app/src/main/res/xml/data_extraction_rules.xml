<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (cloud backup + device-to-device transfer).
    Includes the SQLite database and shared preferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
