<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules (Android 6–11).
    Includes the SQLite database and shared preferences.
    These are backed up to the user's Google Drive automatically.
-->
<full-backup-content>
    <include domain="database" path="." />
    <include domain="sharedpref" path="." />
    <include domain="file" path="." />
</full-backup-content>
